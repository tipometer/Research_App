# ──────────────────────────────────────────────────────────────────────────────
# C1 Sprint — AI Pipeline Migration Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (gitignored) and fill in real values.
# All keys below are OPTIONAL in the DB-first / ENV fallback architecture —
# admin UI at /admin → AI Config → can set them at runtime into the DB instead.
# ENV values take effect only when aiConfigs table has no active row for a provider.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Provider API Keys (pick one config strategy: DB via admin UI OR .env) ──

# OpenAI — used for polling (survey question generation) + brainstorm (idea gen)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — used for synthesis (phase 4) by default
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — used for phases 1-3 (Wide Scan, Gap Detection, Deep Dives)
# with Search Grounding enabled via the google.tools.googleSearch() tool passed
# to generateText's `tools` parameter (Vercel AI SDK v6; the v5
# providerOptions.google.useSearchGrounding flag no longer exists).
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Optional: per-phase model override (otherwise DB modelRouting or seed defaults) ──
# DEFAULT_MODEL_WIDE_SCAN=gemini-2.5-flash
# DEFAULT_MODEL_GAP_DETECTION=gemini-2.5-flash
# DEFAULT_MODEL_DEEP_DIVES=gemini-2.5-flash
# DEFAULT_MODEL_SYNTHESIS=claude-sonnet-4-6
# DEFAULT_MODEL_POLLING=gpt-4.1-mini
# DEFAULT_MODEL_BRAINSTORM=gpt-4.1-mini

# ── Integration test flag (opt-in real provider calls) ────────────────────────
# RUN_INTEGRATION_TESTS=1

# ── API Key Encryption (C2b) ──────────────────────────────────────────────────
# Master key for AES-256-GCM envelope encryption of aiConfigs.apiKey rows.
# Required in ALL environments (dev / staging / prod). Generate with:
#   openssl rand -base64 32
# MUST be a base64-encoded 32-byte value. The server crashes at startup if
# the var is missing or malformed.
#
# Rotation is NOT supported in C2b — changing this value renders all existing
# encrypted rows undecryptable. If rotation is needed, admin must re-save every
# provider key after the rotation. Automated rotation is C3 scope.
MASTER_ENCRYPTION_KEY=

# ── Existing app env (inherited from main branch, leave as-is) ────────────────
# DATABASE_URL=mysql://user:pass@host:3306/db
# JWT_SECRET=...
# VITE_APP_ID=...
# OAUTH_SERVER_URL=...
# OWNER_OPEN_ID=...
